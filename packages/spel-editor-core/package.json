{
  "name": "@agentix-e/spel-editor-core",
  "version": "0.0.0",
  "description": "Web-embeddable Spring Expression Language (SpEL) editor — CodeMirror 6 + spel-ts powered",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist/", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentix-e/spel-ts": "^1.1.0",
    "@codemirror/autocomplete": "^6.0.0",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/lint": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@lezer/lr": "^1.0.0",
    "lit": "^3.0.0"
  },
  "peerDependencies": {
    "@agentix-e/nl2spel": ">=1.1.0"
  },
  "peerDependenciesMeta": {
    "@agentix-e/nl2spel": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@playwright/test": "^1.0.0"
  },
  "keywords": ["spel", "editor", "code-editor", "expression-language", "spring", "codemirror", "web-component"],
  "license": "MIT",
  "author": "AgentiX-E",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentiX-E/spel-editor.git",
    "directory": "packages/spel-editor-core"
  },
  "publishConfig": {
    "access": "public"
  }
}
