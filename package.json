{
  "name": "@agentix-e/spel-editor",
  "version": "0.1.0",
  "description": "Web-embeddable Spring Expression Language (SpEL) editor — CodeMirror 6 + spel-ts powered",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build && pnpm test && pnpm typecheck"
  },
  "dependencies": {
    "@agentix-e/spel-ts": "^1.1.0",
    "@codemirror/autocomplete": "^6.0.0",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/lint": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "lit": "^3.0.0"
  },
  "peerDependencies": {
    "@agentix-e/nl2spel": ">=1.1.0"
  },
  "peerDependenciesMeta": {
    "@agentix-e/nl2spel": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "jsdom": "^29.1.1",
    "tsup": "^8.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "spel",
    "editor",
    "code-editor",
    "expression-language",
    "spring",
    "codemirror",
    "web-component"
  ],
  "license": "MIT",
  "author": "AgentiX-E",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentiX-E/spel-editor.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
