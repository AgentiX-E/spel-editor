{
  "name": "@agentix-e/spel-editor",
  "version": "0.1.1",
  "description": "Web-embeddable Spring Expression Language (SpEL) editor — CodeMirror 6 + spel-ts powered",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run --coverage",
    "test:browser": "playwright test",
    "test:browser:ui": "playwright test --ui",
    "test:all": "pnpm test && pnpm test:browser",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build && pnpm test && pnpm typecheck"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@agentix-e/spel-ts": "^1.1.0",
    "@codemirror/autocomplete": "^6.0.0",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/lint": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "lit": "^3.0.0"
  },
  "peerDependencies": {
    "@agentix-e/nl2spel": ">=1.1.0"
  },
  "peerDependenciesMeta": {
    "@agentix-e/nl2spel": {
      "optional": true
    }
  },
  "devDependencies": {
    "@agentix-e/nl2spel": "^1.1.2",
    "@agentix-e/nl2spel-openai": "^1.1.2",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^3.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "tsup": "^8.0.0",
    "typescript": "^5.8.3",
    "vite": "^8.1.4",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "spel",
    "editor",
    "code-editor",
    "expression-language",
    "spring",
    "codemirror",
    "web-component"
  ],
  "license": "MIT",
  "author": "AgentiX-E",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentiX-E/spel-editor.git"
  },
  "bugs": {
    "url": "https://github.com/AgentiX-E/spel-editor/issues"
  },
  "homepage": "https://github.com/AgentiX-E/spel-editor#readme",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "publishConfig": {
    "access": "public"
  }
}
